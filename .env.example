# =============================================================================
# MedVision AI — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_USER=medvision
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=medvision
DATABASE_URL=postgresql+asyncpg://medvision:change_me_in_prod@postgres:5432/medvision

# ---------------------------------------------------------------------------
# Redis / Celery
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------------------------------------------------------------------------
# MinIO / S3
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=medvision_access
MINIO_SECRET_KEY=change_me_in_prod
MINIO_BUCKET=medvision
MINIO_SECURE=false

# For production (real S3):
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=eu-central-1
# S3_BUCKET=medvision-prod

# ---------------------------------------------------------------------------
# NVIDIA Triton
# ---------------------------------------------------------------------------
TRITON_GRPC_URL=triton:8001
TRITON_HTTP_URL=http://triton:8000
TRITON_MODEL_REPO_PATH=/models

# ---------------------------------------------------------------------------
# ClearML
# ---------------------------------------------------------------------------
CLEARML_API_HOST=https://api.clear.ml
CLEARML_API_ACCESS_KEY=your_access_key_here
CLEARML_API_SECRET_KEY=your_secret_key_here
CLEARML_WEB_HOST=https://app.clear.ml
CLEARML_FILES_HOST=https://files.clear.ml

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# Anthropic (Report Service)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=2048

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
JAEGER_ENDPOINT=http://jaeger:14268/api/traces
OTEL_SERVICE_NAME=medvision
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
PROMETHEUS_METRICS_PATH=/metrics

# ---------------------------------------------------------------------------
# App settings
# ---------------------------------------------------------------------------
ENVIRONMENT=development         # development | staging | production
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
DOCS_ENABLED=true               # set false in production
MAX_UPLOAD_SIZE_MB=512
ALLOWED_ORIGINS=http://localhost:3000,http://localhost
